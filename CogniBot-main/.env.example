# CogniBot / EV Finder Web Client
# Environment Variables Configuration

# 1. Open Charge Map API Key (Required for Live Station Overviews)
# Obtain from: https://openchargemap.org/site/developer
VITE_OCM_API_KEY="INSERT_YOUR_COPIED_KEY_HERE"

# 2. Firebase App Config (Required for User Auth / Dashboard)
# Current configured in src/lib/firebase.js
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
